{
  "family": "group-4-react-app",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::518647659327:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::518647659327:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "react-app-container",
      "image": "518647659327.dkr.ecr.us-east-2.amazonaws.com/group-4-react-app:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 80,
          "hostPort": 80,
          "protocol": "tcp"
        }
      ]
    }
  ]
}
